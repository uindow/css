{
    "name": "@uindow/css",
    "version": "0.1.1",
    "description": "CSS Selector Generator",
    "main": "index.js",
    "module": "index.mjs",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "require": "./index.js",
            "import": "./index.mjs"
        }
    },
    "files": [
        "index.js",
        "index.mjs",
        "types/index.d.ts"
    ],
    "license": "Apache-2.0",
    "author": "Mark Jivko <mark@uindow.com> (https://uindow.com)",
    "homepage": "https://uindow.com",
    "keywords": [
        "css",
        "selector",
        "generator",
        "uindow"
    ],
    "scripts": {
        "format": "prettier --write \"{src,types}/**/*.ts\"",
        "lint": "eslint --fix --cache \"src/**/*.ts\"",
        "build": "npm run lint && tsc && npm run format && node ./tools/build.cjs"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "8.60.0",
        "esbuild": "0.25.9",
        "eslint": "8.57.1",
        "eslint-config-prettier": "8.10.0",
        "eslint-plugin-prettier": "4.2.1",
        "prettier": "2.8.8",
        "typescript": "6.0.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/uindow/css.git"
    },
    "publishConfig": {
        "access": "public"
    }
}
